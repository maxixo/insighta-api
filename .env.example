PORT=4000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017
DB_NAME=profile_db
CORS_ORIGIN=*
SEED_PROFILES_SOURCE=https://drive.google.com/uc?export=download&id=1Up06dcS9OfUEnDj_u6OV_xTRntupFhPH
APP_BASE_URL=http://localhost:4000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_SCOPE=read:user user:email
GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_REDIRECT_URI=http://localhost:4000/auth/github/callback
AUTH_COOKIE_SECURE=false
AUTH_PKCE_COOKIE_MAX_AGE_MS=600000
ENABLE_DOCS=true
TRUST_PROXY=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_MAX_REQUESTS=60
REQUEST_TIMEOUT_MS=15000
HEADERS_TIMEOUT_MS=16000
KEEP_ALIVE_TIMEOUT_MS=5000
SHUTDOWN_TIMEOUT_MS=10000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=0
